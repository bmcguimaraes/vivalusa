# .env.example — copy to .env and fill in values
# Lines marked [REQUIRED] crash the app at startup if missing.

# ── Database [REQUIRED] ────────────────────────────────────────────────────
MONGO_URL=mongodb://localhost:27017
DB_NAME=vivalusa

# ── Auth [REQUIRED] ────────────────────────────────────────────────────────
JWT_SECRET=                    # python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_PASSWORD=                # Strong password, min 16 chars — no default exists

# ── Server [REQUIRED] ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000   # Production: https://vivalusa.com
ENVIRONMENT=development              # Production: production

# ── Stripe [REQUIRED] ─────────────────────────────────────────────────────
STRIPE_API_KEY=                # sk_test_... (test) or sk_live_... (production)
STRIPE_WEBHOOK_SECRET=         # whsec_... — from Stripe Dashboard → Webhooks

# ── Image Storage [REQUIRED] ──────────────────────────────────────────────
S3_ENDPOINT_URL=               # https://<account-id>.r2.cloudflarestorage.com (R2) or omit for AWS S3
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=vivalusa-images
S3_REGION=auto                 # 'auto' for R2; your region for AWS S3

# ── PayPal [optional — required if PayPal enabled] ─────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox            # Remove or change to 'live' for production

# ── Email [optional — order confirmation emails won't send if missing] ─────
RESEND_API_KEY=                # from resend.com dashboard

# ── Error Monitoring [optional] ───────────────────────────────────────────
SENTRY_DSN=

# ── Admin seed [optional] ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@vivalusa.com

# ── Frontend build-time (set before yarn build or in Docker ARG) ──────────
REACT_APP_BACKEND_URL=http://localhost:8000
REACT_APP_SENTRY_DSN=
